<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MikoEmergency" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sos_red</item>
        <item name="colorPrimaryVariant">@color/sos_red_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/mesh_purple</item>
        <item name="colorSecondaryVariant">@color/mesh_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- TextInputLayout -->
        <item name="colorControlActivated">@color/sos_red</item>
        <item name="colorControlHighlight">@color/sos_red</item>

        <!-- Switch -->
        <item name="colorControlNormal">@color/text_hint</item>
    </style>

    <style name="Theme.MikoEmergency.Splash" parent="Theme.MikoEmergency">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

</resources>
